{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default base configuration for all Inthememory projects.",
  "assigneesFromCodeOwners": true,
  "assigneesSampleSize": 1,
  "automerge": false,
  "dependencyDashboard": true,
  "extends": [
    ":ignoreModulesAndTests",
    ":semanticPrefixFixDepsChoreOthers",
    "helpers:disableTypesNodeMajor",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests",
    "github>Inthememory/renovate-config//preset/commit",
    "github>Inthememory/renovate-config//preset/schedule",
    "github>Inthememory/renovate-config//preset/ignore",
    "replacements:all",
    "workarounds:all"
  ],
  "forkProcessing": "disabled",
  "ignoreUnstable": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "2 days"
    },
    {
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "2 days"
    }
  ],
  "prConcurrentLimit": 20,
  "prCreation": "immediate",
  "prHourlyLimit": 0,
  "rangeStrategy": "auto",
  "rebaseWhen": "auto",
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "updateNotScheduled": true,
  "platformAutomerge": true
}
